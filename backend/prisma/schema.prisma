datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

model User {
  id            String               @id @default(uuid())
  email         String               @unique
  password      String?
  googleId      String?              @unique
  plans         Plan[]
  refreshTokens RefreshToken[]
  resetTokens   PasswordResetToken[]
  createdAt     DateTime             @default(now())
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Plan {
  id        String     @id @default(uuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id])
  rawInput  String
  mode      String
  summary   String?
  createdAt DateTime   @default(now())
  items     PlanItem[]
}

model PlanItem {
  id     String @id @default(uuid())
  planId String
  plan   Plan   @relation(fields: [planId], references: [id])
  order  Int
  name   String
  lat    Float
  lng    Float
  type   String
  time   String
}

model ApiUsage {
  id        String   @id @default(uuid())
  userId    String   @default("anonymous")
  ipAddress String
  userAgent String
  endpoint  String
  cost      Float    @default(0.0)
  timestamp DateTime @default(now())

  @@index([userId])
  @@index([ipAddress])
  @@index([timestamp])
}
